{
  "name": "sec-form",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "turbo run db:generate --filter=@sec-form/db",
    "db:migrate": "turbo run db:migrate --filter=@sec-form/db",
    "db:seed": "turbo run db:seed --filter=@sec-form/db",
    "start": "turbo run start"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
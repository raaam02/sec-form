# PostgreSQL Connection String
DATABASE_URL=postgres://postgres:postgres@localhost:5432/secform

# Redis Connection URL
REDIS_URL=redis://localhost:6379

# Google Generative AI API Key (required for real Gemini responses, mock-fallback active if missing)
GEMINI_API_KEY=your_gemini_api_key_here

# Auth.js Configuration
NEXTAUTH_SECRET=hackathon-secret-key-1234567890
NEXTAUTH_URL=http://localhost:3000

# Google OAuth Credentials (for production authentication, credentials bypass active in development)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
